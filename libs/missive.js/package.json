{
    "name": "missive.js",
    "description": "A Service Bus with Envelope and Stamps fully-typed for Typescript as well as Middlewares",
    "keywords": [
        "service bus",
        "bus",
        "envelope",
        "stamp",
        "middleware",
        "typescript",
        "missive",
        "cqrs"
    ],
    "author": "Sébastien Morel <plopix@gmail.com>",
    "license": "MIT",
    "contributors": [
        "Sébastien Morel <plopix@gmail.com>",
        "Anaël Chardan"
    ],
    "version": "1.0.0",
    "type": "module",
    "main": "./build/index.cjs",
    "module": "./build/index.js",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "import": "./build/index.js",
            "require": "./build/index.cjs"
        }
    },
    "types": "./build/index.d.ts",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^25.9.4",
        "eslint-config-custom": "workspace:*",
        "tsconfig": "workspace:*",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "vite": "^6.4.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Missive-js/missive.js.git"
    },
    "scripts": {
        "types:check": "tsc --noEmit",
        "build": "cp ../../README.md ../../LICENSE . && tsup",
        "watch": "tsc -W --preserveWatchOutput",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "vitest run"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "package.json",
        "build",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ]
}
